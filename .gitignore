cat > .gitignore << 'EOF'
# Terraform state - never commit these
terraform.tfstate
terraform.tfstate.backup
.terraform/
.terraform.lock.hcl
*.tfvars
*.tfvars.json

# AWS credentials - never commit these
.env
.env.local
*.csv
credentials

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Docker
.dockerignore

# macOS
.DS_Store

# IDE
.vscode/
.idea/
EOF